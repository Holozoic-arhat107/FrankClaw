# FrankClaw Docker Environment
# Copy to .env.docker and fill in your values:
#   cp .env.docker.example .env.docker

# --- Model Provider API Keys ---
# Only fill in the providers you use.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# --- Channel Tokens ---
# Telegram: get from @BotFather
TELEGRAM_BOT_TOKEN=

# WhatsApp Business API
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=
WHATSAPP_VERIFY_TOKEN=

# Discord bot token
DISCORD_BOT_TOKEN=

# Slack
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=

# --- Embedding Providers (for memory/RAG) ---
# Only needed if you enable memory in frankclaw.json.
# GEMINI_API_KEY=
# VOYAGE_API_KEY=

# --- Optional ---
# Session encryption (32 bytes, base64-encoded). Generate with:
#   openssl rand -base64 32
FRANKCLAW_MASTER_KEY=

# VirusTotal file scanning
VIRUSTOTAL_API_KEY=

# Browser mutations (click/type/press). Set to 1 to enable.
# FRANKCLAW_ALLOW_BROWSER_MUTATIONS=0
